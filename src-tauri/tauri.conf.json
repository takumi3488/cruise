{
  "productName": "cruise",
  "identifier": "io.github.smartcrabai.cruise",
  "build": {
    "beforeDevCommand": "pnpm --dir ui run dev",
    "beforeBuildCommand": "pnpm --dir ui run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cruise",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
